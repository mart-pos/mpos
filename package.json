{
  "name": "mpos-core",
  "version": "0.1.0",
  "description": "Local desktop bridge between MartPOS and receipt printers.",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "bundle": "pnpm tauri build && node scripts/collect-artifacts.mjs",
    "bundle:mac": "pnpm tauri build --bundles app && node scripts/collect-artifacts.mjs",
    "bundle:linux": "pnpm tauri build --bundles appimage,deb,rpm && node scripts/collect-artifacts.mjs",
    "bundle:windows": "pnpm tauri build --bundles nsis,msi && node scripts/collect-artifacts.mjs",
    "artifacts:collect": "node scripts/collect-artifacts.mjs",
    "preview": "vite preview",
    "tauri": "tauri"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "geist": "^1.7.0",
    "lucide-react": "^1.7.0",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "shadcn": "^4.1.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "typescript": "~5.8.3",
    "vite": "^7.0.4"
  }
}
